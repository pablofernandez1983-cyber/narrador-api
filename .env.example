# Supabase / Postgres (reusar el mismo de hechizo-reporte-nuevo)
DATABASE_URL=postgresql://...

# Tigris S3 (reusar mismo bucket que hechizo — solo agrega el prefijo narrador/)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=https://t3.storageapi.dev
AWS_DEFAULT_REGION=sjc
AWS_S3_BUCKET_NAME=

# API keys (van como vars de entorno en Railway, nunca en el cliente)
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_TTS_API_KEY=AIzaSy...

# Clave de acceso al backend (inventate algo de 40+ chars random)
# Ej: openssl rand -base64 32
NARRADOR_API_KEY=
